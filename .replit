modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f 'artifacts/api-server/dist/index.mjs' 2>/dev/null; sleep 1; cd /home/runner/workspace/artifacts/api-server && pnpm run build && while true; do PORT=8080 NODE_ENV=development node --enable-source-maps /home/runner/workspace/artifacts/api-server/dist/index.mjs; echo '[api-server] exited, restarting in 3s...'; sleep 3; done"
waitForPort = 8080

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f 'artifacts/shop-app' 2>/dev/null; sleep 1; PORT=22696 BASE_PATH=/ pnpm --filter @workspace/shop-app run dev"
waitForPort = 22696

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 3002
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 22696
externalPort = 3000
